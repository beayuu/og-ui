DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=adopt_a_reef
DB_USER=root
DB_PASS=

# Set to 1 when serving PHP API over HTTPS (secure session cookie)
SESSION_SECURE=0

# Only if the browser calls PHP directly on another origin (e.g. Vite on :5173, PHP on :8080).
# Must be the exact frontend origin. Leave empty when using the Node dev proxy (recommended).
# CORS_ALLOW_ORIGIN=http://127.0.0.1:5000
